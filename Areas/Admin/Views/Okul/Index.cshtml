@model IEnumerable<deneme.Models.Okul>
@{
    ViewData["Title"] = "Okullar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Okullar</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Okul Ekle
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="mb-3">
            <div class="row">
                <div class="col-md-8">
                    <input type="text" name="search" class="form-control" placeholder="Okul adı, ülke veya website ile ara..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-secondary w-100">Ara</button>
                </div>
            </div>
        </form>

        @if (ViewBag.TotalCount > 0)
        {
            <div class="alert alert-info">
                Toplam <strong>@ViewBag.TotalCount</strong> okul bulundu.
            </div>
        }

        <table class="table table-striped table-hover" id="okullarTable">
            <thead>
                <tr>
                    <th>Okul Adı</th>
                    <th>Ülke</th>
                    <th>Website</th>
                    <th>Koordinatlar</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.OkulAd</td>
                        <td>
                            <country-flag country-name="@item.Ulke?.UlkeIsim"></country-flag>
                            @item.Ulke?.UlkeIsim
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.InternetSitesi))
                            {
                                <a href="@item.InternetSitesi" target="_blank" class="text-decoration-none">
                                    <i class="fas fa-external-link-alt"></i> Website
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.Latitude.HasValue && item.Longitude.HasValue)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-map-marker-alt"></i> 
                                    @item.Latitude.Value.ToString("F4"), @item.Longitude.Value.ToString("F4")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Koordinat yok</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.OkulId" class="btn btn-sm btn-info" title="Detay">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.OkulId" class="btn btn-sm btn-warning" title="Düzenle">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.OkulId" class="btn btn-sm btn-danger" title="Sil">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Sayfa navigasyonu">
                <ul class="pagination justify-content-center">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)&pageSize=@ViewBag.PageSize&search=@ViewBag.Search">
                                <i class="fas fa-chevron-left"></i> Önceki
                            </a>
                        </li>
                    }
                    
                    @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?page=@i&pageSize=@ViewBag.PageSize&search=@ViewBag.Search">@i</a>
                        </li>
                    }
                    
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)&pageSize=@ViewBag.PageSize&search=@ViewBag.Search">
                                Sonraki <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        // madde 18 - jquerry datatables kütüphanesi 
        $(document).ready(function() {
            $('#okullarTable').DataTable({
                "paging": false,
                "searching": false,
                "info": false,
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json"
                }
            });
        });
    </script>
}


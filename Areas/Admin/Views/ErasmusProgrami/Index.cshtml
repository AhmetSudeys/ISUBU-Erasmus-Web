@model IEnumerable<deneme.Models.ErasmusProgrami>
@{
    ViewData["Title"] = "Erasmus Programları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Erasmus Programları</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Program Ekle
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="mb-3" action="@Url.Action("Index")">
            <div class="row">
                <div class="col-md-8">
                    <input type="text" name="search" class="form-control" placeholder="Erasmus Kodu, Okul, Bölüm, Dil veya Eğitim Seviyesi ile ara..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-2">
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="fas fa-search"></i> Ara
                    </button>
                </div>
                <div class="col-md-2">
                    @if (!string.IsNullOrEmpty(ViewBag.Search))
                    {
                        <a href="@Url.Action("Index", new { page = 1, pageSize = ViewBag.PageSize })" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-times"></i> Temizle
                        </a>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.Search))
            {
                <div class="mt-2">
                    <small class="text-muted">
                        <i class="fas fa-info-circle"></i> "<strong>@ViewBag.Search</strong>" için <strong>@ViewBag.TotalCount</strong> sonuç bulundu.
                    </small>
                </div>
            }
        </form>

        <div class="table-responsive">
            <table class="table table-striped table-hover" id="programsTable">
                <thead>
                    <tr>
                        <th style="min-width: 120px;">Erasmus Kodu</th>
                        <th style="min-width: 250px;">Okul</th>
                        <th style="min-width: 200px;">Bölüm</th>
                        <th style="min-width: 100px;">Dil</th>
                        <th style="min-width: 120px;">Eğitim Seviyesi</th>
                        <th style="min-width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ErasmusKodu</td>
                            <td style="max-width: 300px; word-wrap: break-word; white-space: normal;">
                                <div style="font-size: 14px; line-height: 1.4;">@item.Okul?.OkulAd</div>
                            </td>
                            <td style="max-width: 250px; word-wrap: break-word; white-space: normal;">
                                <div style="font-size: 14px; line-height: 1.4;">
                                    @if (!string.IsNullOrEmpty(item.BolumAdi) && item.BolumAdi.Length > 40)
                                    {
                                        <span title="@item.BolumAdi">@item.BolumAdi.Substring(0, 40)...</span>
                                    }
                                    else
                                    {
                                        @item.BolumAdi
                                    }
                                </div>
                            </td>
                            <td>@item.Dil?.DilAdi</td>
                            <td>
                                @if (item.EgitimSeviyeleri != null && item.EgitimSeviyeleri.Any())
                                {
                                    @string.Join(", ", item.EgitimSeviyeleri.Select(es => es.EgitimSeviyesiAdi))
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.ErasmusId" class="btn btn-sm btn-info" title="Detaylar">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.ErasmusId" class="btn btn-sm btn-warning" title="Düzenle">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.ErasmusId" class="btn btn-sm btn-danger" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Sayfa navigasyonu">
                <ul class="pagination justify-content-center mt-4">
                    @{
                        int currentPage = ViewBag.CurrentPage;
                        int totalPages = ViewBag.TotalPages;
                        int pageSize = ViewBag.PageSize;
                        string search = ViewBag.Search ?? "";
                        
                        // URL helper ile search parametresini encode et
                        var routeValues = new Dictionary<string, object>
                        {
                            { "pageSize", pageSize }
                        };
                        if (!string.IsNullOrEmpty(search))
                        {
                            routeValues["search"] = search;
                        }
                        
                        // Önceki sayfa butonu
                        routeValues["page"] = currentPage - 1;
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", routeValues)" aria-label="Önceki">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>
                        
                        // İlk sayfa
                        if (currentPage > 3)
                        {
                            routeValues["page"] = 1;
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", routeValues)">1</a>
                            </li>
                            if (currentPage > 4)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }
                        
                        // Mevcut sayfanın etrafındaki sayfalar
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);
                        
                        for (int i = startPage; i <= endPage; i++)
                        {
                            routeValues["page"] = i;
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", routeValues)">@i</a>
                            </li>
                        }
                        
                        // Son sayfa
                        if (currentPage < totalPages - 2)
                        {
                            if (currentPage < totalPages - 3)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            routeValues["page"] = totalPages;
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", routeValues)">@totalPages</a>
                            </li>
                        }
                        
                        // Sonraki sayfa butonu
                        routeValues["page"] = currentPage + 1;
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", routeValues)" aria-label="Sonraki">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    }
                </ul>
                <div class="text-center mt-2">
                    <small class="text-muted">
                        Toplam @ViewBag.TotalCount kayıt - Sayfa @ViewBag.CurrentPage / @ViewBag.TotalPages
                    </small>
                </div>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // madde 18 - jquerry kütüphanesi 
            $('#programsTable').DataTable({
                "paging": false,
                "searching": false,
                "info": false,
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json"
                }
            });
        });
    </script>
}


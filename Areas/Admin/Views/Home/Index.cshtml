@{
    ViewData["Title"] = "Admin Ana Sayfa";
    var stats = ViewBag.Stats as dynamic;
}

<div class="row">
    <div class="col-12">
        <h2 class="mb-4">Admin Paneli</h2>
    </div>
</div>

<div class="row">
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Ülke Sayısı</h6>
                        <h2 class="mb-0">@stats?.UlkeSayisi</h2>
                    </div>
                    <i class="fas fa-globe fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Okul Sayısı</h6>
                        <h2 class="mb-0">@stats?.OkulSayisi</h2>
                    </div>
                    <i class="fas fa-university fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-info">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Program Sayısı</h6>
                        <h2 class="mb-0">@stats?.ProgramSayisi</h2>
                    </div>
                    <i class="fas fa-book fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Yorum Sayısı</h6>
                        <h2 class="mb-0">@stats?.YorumSayisi</h2>
                    </div>
                    <i class="fas fa-comments fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Hızlı İşlemler</h5>
            </div>
            <div class="card-body">
                <a href="@Url.Action("Index", "ErasmusProgrami", new { area = "Admin" })" class="btn btn-primary btn-lg w-100 mb-2">
                    <i class="fas fa-list"></i> Erasmus Programlarını Yönet
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        @await Component.InvokeAsync("SonYorumlar", new { count = 5 })
    </div>
</div>


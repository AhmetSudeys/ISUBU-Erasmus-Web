<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ISPARTA UYGULAMALI BİLİMLER ÜNİVERSİTESİ</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/deneme.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Üst Bar -->
        <div class="top-bar">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <button class="btn-link-top">Bağlantılar <i class="bi bi-arrow-up"></i></button>
                        <span class="language-selector">TR | EN</span>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="social-icons">
                            <a href="#" class="social-icon"><i class="fab fa-facebook"></i></a>
                            <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="social-icon"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                            <a href="#" class="social-icon"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Ana Header -->
        <div class="main-header">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-md-2">
                        <div class="logo-section">
                            <div class="logo-circle">İB</div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="university-text-section">
                            <h1 class="university-name">ISPARTA UYGULAMALI BİLİMLER ÜNİVERSİTESİ</h1>
                            <h2 class="department-name">ERASMUS KOORDİNATÖRLÜĞÜ</h2>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <form asp-controller="Home" asp-action="Ara" method="get" class="search-box">
                            <input type="text" name="q" placeholder="Sitede ara" class="form-control" value="@Context.Request.Query["q"]" />
                            <button type="submit" class="search-btn"><i class="bi bi-search"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Navigasyon Menüsü --> <!-- madde 11 tag helper kullanımları-->
        <nav class="main-navbar">
            <div class="container-fluid">
                <ul class="nav-menu">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Ana Sayfa
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="IkiliAnlasmalar">
                            İkili Anlaşmalar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Iletisim">
                            İletişim
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-user-shield"></i> Admin Paneli
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-link logout-btn">
                                    <i class="fas fa-sign-out-alt"></i> Çıkış
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-user-cog"></i> Admin Girişi
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>
    
    <main role="main" style="padding: 0;">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12 text-center">
                    <p>&copy; 2025 - ISPARTA UYGULAMALI BİLİMLER ÜNİVERSİTESİ - ERASMUS KOORDİNATÖRLÜĞÜ</p>
                </div>
            </div>
        </div>
    </footer>
    
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
